rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Core Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isTheOwner() {
      return isSignedIn() && request.auth.uid == "RU9vfuH9VyS6arM2kRFJ9eEpAeL2";
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasUserDoc() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isBos() {
      return isTheOwner() || (
        hasUserDoc() && getUserData().role == 'bos'
      );
    }

    function isBosGlobal() {
      return isTheOwner() || (
        hasUserDoc() && getUserData().role == 'bos' &&
        (getUserData().get('branchId', '') == '' || getUserData().get('branchId', null) == null)
      );
    }

    function isMandor() {
      return hasUserDoc() && getUserData().role == 'mandor';
    }

    function isMandorGlobal() {
      return isMandor() && (
        getUserData().get('branchId', '') == '' || getUserData().get('branchId', null) == null
      );
    }

    function isAssignedToBranch(branchId) {
      return isSignedIn() && (
        isBosGlobal() ||
        isMandorGlobal() ||
        (hasUserDoc() && getUserData().get('branchId', null) == branchId)
      );
    }

    // --- Collection Groups ---
    
    // Collection: salarySlips
    match /salarySlips/{slipId} {
      // Bos and Owner can list all or any branch
      allow list: if isSignedIn() && (
        request.auth.uid == "RU9vfuH9VyS6arM2kRFJ9eEpAeL2" || 
        request.auth.token.email == "alfathpulsa27@gmail.com" ||
        isBos()
      );
      
      // Regular users can only list their own
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow get: if isSignedIn() && (
        request.auth.uid == "RU9vfuH9VyS6arM2kRFJ9eEpAeL2" || 
        request.auth.token.email == "alfathpulsa27@gmail.com" ||
        isBos() || 
        resource.data.userId == request.auth.uid
      );
      
      allow create, update, delete: if isSignedIn() && (
        request.auth.uid == "RU9vfuH9VyS6arM2kRFJ9eEpAeL2" || 
        request.auth.token.email == "alfathpulsa27@gmail.com" ||
        isBos()
      );
    }

    // Collection: users
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isBos() || (
        isSignedIn() && request.auth.uid == userId && 
        request.resource.data.get('role', 'karyawan') == resource.data.get('role', 'karyawan') &&
        request.resource.data.get('branchId', '') == resource.data.get('branchId', '') &&
        request.resource.data.get('baseSalary', 0) == resource.data.get('baseSalary', 0)
      );
      allow delete: if isBos();

      match /{allChildren=**} {
        allow read: if isSignedIn();
        allow write: if isBos() || (isSignedIn() && request.auth.uid == userId);
      }
    }

    // Collection: settings
    match /settings/{document=**} {
      allow read: if isSignedIn();
      allow write: if isBos();
    }

    // Collection: banks
    match /banks/{bankId} {
      allow read: if isSignedIn() && (isBosGlobal() || isAssignedToBranch(resource.data.branchId));
      allow create: if isSignedIn() && (isBosGlobal() || isAssignedToBranch(request.resource.data.branchId));
      allow update, delete: if isSignedIn() && (isBosGlobal() || isAssignedToBranch(resource.data.branchId));
    }

    // Collection: branches
    match /branches/{branchId} {
      allow read: if isSignedIn();
      allow create: if isBosGlobal();
      allow update: if isSignedIn() && (isBosGlobal() || isAssignedToBranch(branchId));
      allow delete: if isBosGlobal();
      
      match /deposits/{depositId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && (isBosGlobal() || isAssignedToBranch(branchId));
      }
    }

    // Collection: customers
    match /customers/{customerId} {
      allow read: if isSignedIn() && !isMandor() && (isBosGlobal() || isAssignedToBranch(resource.data.branchId));
      allow create: if isSignedIn() && !isMandor() && (isBosGlobal() || isAssignedToBranch(request.resource.data.branchId));
      allow update, delete: if isSignedIn() && !isMandor() && (isBosGlobal() || isAssignedToBranch(resource.data.branchId));

      match /transactions/{transactionId} {
        allow read: if isSignedIn() && !isMandor() && (isBosGlobal() || isAssignedToBranch(get(/databases/$(database)/documents/customers/$(customerId)).data.branchId));
        allow write: if isSignedIn() && !isMandor() && (isBosGlobal() || isAssignedToBranch(get(/databases/$(database)/documents/customers/$(customerId)).data.branchId));
      }
    }

    // Collection: savings
    match /savings/{savingId} {
      allow read: if isSignedIn() && !isMandor() && (isBosGlobal() || isAssignedToBranch(resource.data.branchId));
      allow create: if isSignedIn() && !isMandor() && (isBosGlobal() || isAssignedToBranch(request.resource.data.branchId));
      allow update, delete: if isSignedIn() && !isMandor() && (isBosGlobal() || isAssignedToBranch(resource.data.branchId));

      match /transactions/{transactionId} {
        allow read: if isSignedIn() && !isMandor() && (isBosGlobal() || isAssignedToBranch(get(/databases/$(database)/documents/savings/$(savingId)).data.branchId));
        allow write: if isSignedIn() && !isMandor() && (isAssignedToBranch(get(/databases/$(database)/documents/savings/$(savingId)).data.branchId));
      }
    }

    // Collection: voucherRecaps
    match /voucherRecaps/{recapId} {
      allow read: if isSignedIn() && (isBosGlobal() || isAssignedToBranch(resource.data.branchId));
      allow create: if isSignedIn() && (isBosGlobal() || isAssignedToBranch(request.resource.data.branchId));
      allow update, delete: if isSignedIn() && (
        isBosGlobal() || 
        (isAssignedToBranch(resource.data.branchId) && resource.data.get('status', 'reported') == 'draft')
      );
    }
  }
}

