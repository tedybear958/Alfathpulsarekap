rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isBos() {
      return isAuthenticated() && (
        request.auth.uid == "RU9vfuH9VyS6arM2kRFJ9eEpAeL2" ||
        request.auth.token.email == "alfathpulsa27@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'bos')
      );
    }

    function isMandor() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'mandor';
    }

    function isKaryawan() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'karyawan';
    }

    function isBosGlobal() {
      return isBos() && (
        !exists(/databases/$(database)/documents/users/$(request.auth.uid)) || 
        !('branchId' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data) || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.branchId == null || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.branchId == ''
      );
    }

    function isAssignedToBranch(branchId) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.branchId == branchId;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (request.auth.uid == userId || isBos());
      allow delete: if isBos();
    }

    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isBos();
    }

    match /banks/{bankId} {
      allow read: if isAuthenticated() && (isBosGlobal() || isAssignedToBranch(resource.data.branchId));
      allow create: if isAuthenticated() && (isBosGlobal() || isAssignedToBranch(request.resource.data.branchId));
      allow update, delete: if isAuthenticated() && (isBosGlobal() || isAssignedToBranch(resource.data.branchId));
    }

    match /branches/{branchId} {
      allow read: if isAuthenticated();
      allow create: if isBosGlobal();
      allow update: if isAuthenticated() && (isBosGlobal() || isAssignedToBranch(branchId));
      allow delete: if isBosGlobal();
      
      match /deposits/{depositId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && (isBosGlobal() || isMandor() || isAssignedToBranch(branchId));
      }
    }

    match /customers/{customerId} {
      allow read: if isAuthenticated() && (isBosGlobal() || isMandor() || isAssignedToBranch(resource.data.branchId));
      allow create: if isAuthenticated() && (isBosGlobal() || isAssignedToBranch(request.resource.data.branchId));
      allow update, delete: if isAuthenticated() && (isBosGlobal() || isAssignedToBranch(resource.data.branchId));

      match /transactions/{txId} {
        allow read: if isAuthenticated() && (isBosGlobal() || isMandor() || isAssignedToBranch(get(/databases/$(database)/documents/customers/$(customerId)).data.branchId));
        allow write: if isAuthenticated() && (isBosGlobal() || isMandor() || isAssignedToBranch(get(/databases/$(database)/documents/customers/$(customerId)).data.branchId));
      }
    }

    match /savings/{savingId} {
      allow read: if isAuthenticated() && (isBosGlobal() || isAssignedToBranch(resource.data.branchId));
      allow create: if isAuthenticated() && (isBosGlobal() || isAssignedToBranch(request.resource.data.branchId));
      allow update, delete: if isAuthenticated() && (isBosGlobal() || isAssignedToBranch(resource.data.branchId));

      match /transactions/{txId} {
        allow read: if isAuthenticated() && (isBosGlobal() || isAssignedToBranch(get(/databases/$(database)/documents/savings/$(savingId)).data.branchId));
        allow write: if isAuthenticated() && (isBosGlobal() || isAssignedToBranch(get(/databases/$(database)/documents/savings/$(savingId)).data.branchId));
      }
    }

    match /voucherRecaps/{recapId} {
      allow read: if isAuthenticated() && (isBosGlobal() || isAssignedToBranch(resource.data.branchId));
      allow create: if isAuthenticated() && (isBosGlobal() || isAssignedToBranch(request.resource.data.branchId));
      allow update: if isAuthenticated() && (
        isBosGlobal() || 
        (isAssignedToBranch(resource.data.branchId) && resource.data.get('status', 'reported') == 'draft')
      );
      allow delete: if isAuthenticated() && (
        isBosGlobal() || 
        (isAssignedToBranch(resource.data.branchId) && resource.data.get('status', 'reported') == 'draft')
      );
    }
  }
}
