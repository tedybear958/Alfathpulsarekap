rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helpers
    function isAuthenticated() {
      return request.auth != null;
    }

    function isBos() {
      return isAuthenticated() && (
        request.auth.uid == "RU9vfuH9VyS6arM2kRFJ9eEpAeL2" ||
        request.auth.token.email == "alfathpulsa27@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'bos')
      );
    }

    // Collection: salarySlips
    match /salarySlips/{document=**} {
      allow read: if isAuthenticated() && (
        isBosGlobal() || 
        (resource.data.branchId != null && isAssignedToBranch(resource.data.branchId)) || 
        resource.data.userId == request.auth.uid
      );
      allow write: if isBos();
    }

    // Collection: users
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isBos() || (
        isAuthenticated() && request.auth.uid == userId && 
        request.resource.data.get('role', 'karyawan') == resource.data.get('role', 'karyawan') &&
        request.resource.data.get('branchId', '') == resource.data.get('branchId', '') &&
        request.resource.data.get('baseSalary', 0) == resource.data.get('baseSalary', 0)
      );
      allow delete: if isBos();
    }
    match /users/{userId}/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isBos() || (isAuthenticated() && request.auth.uid == userId);
    }

    function isBosGlobal() {
      return isAuthenticated() && (
        request.auth.uid == "RU9vfuH9VyS6arM2kRFJ9eEpAeL2" || 
        request.auth.token.email == "alfathpulsa27@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'bos' &&
         (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('branchId', null) == null || 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('branchId', '') == ''))
      );
    }

    function isAssignedToBranch(branchId) {
      return isAuthenticated() && (
        isBosGlobal() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('branchId', null) == branchId)
      );
    }

    // Settings
    match /settings/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isBos();
    }

    // Banks
    match /banks/{document=**} {
      allow read: if isAuthenticated() && (isBosGlobal() || isAssignedToBranch(resource.data.branchId));
      allow create: if isAuthenticated() && (isBosGlobal() || isAssignedToBranch(request.resource.data.branchId));
      allow update, delete: if isAuthenticated() && (isBosGlobal() || isAssignedToBranch(resource.data.branchId));
    }

    // Branches
    match /branches/{branchId} {
      allow read: if isAuthenticated();
      allow create: if isBosGlobal();
      allow update: if isAuthenticated() && (isBosGlobal() || isAssignedToBranch(branchId));
      allow delete: if isBosGlobal();
      
      match /deposits/{document=**} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && (isBosGlobal() || isAssignedToBranch(branchId));
      }
    }

    // Customers (Debts)
    match /customers/{customerId} {
      allow read: if isAuthenticated() && (isBosGlobal() || isAssignedToBranch(resource.data.branchId));
      allow create: if isAuthenticated() && (isBosGlobal() || isAssignedToBranch(request.resource.data.branchId));
      allow update, delete: if isAuthenticated() && (isBosGlobal() || isAssignedToBranch(resource.data.branchId));

      match /transactions/{document=**} {
        allow read: if isAuthenticated() && (isBosGlobal() || isAssignedToBranch(get(/databases/$(database)/documents/customers/$(customerId)).data.branchId));
        allow write: if isAuthenticated() && (isBosGlobal() || isAssignedToBranch(get(/databases/$(database)/documents/customers/$(customerId)).data.branchId));
      }
    }

    // Savings
    match /savings/{savingId} {
      allow read: if isAuthenticated() && (isBosGlobal() || isAssignedToBranch(resource.data.branchId));
      allow create: if isAuthenticated() && (isBosGlobal() || isAssignedToBranch(request.resource.data.branchId));
      allow update, delete: if isAuthenticated() && (isBosGlobal() || isAssignedToBranch(resource.data.branchId));

      match /transactions/{document=**} {
        allow read: if isAuthenticated() && (isBosGlobal() || isAssignedToBranch(get(/databases/$(database)/documents/savings/$(savingId)).data.branchId));
        allow write: if isAuthenticated() && (isAssignedToBranch(get(/databases/$(database)/documents/savings/$(savingId)).data.branchId));
      }
    }

    // Voucher Recaps
    match /voucherRecaps/{document=**} {
      allow read: if isAuthenticated() && (isBosGlobal() || isAssignedToBranch(resource.data.branchId));
      allow create: if isAuthenticated() && (isBosGlobal() || isAssignedToBranch(request.resource.data.branchId));
      allow update, delete: if isAuthenticated() && (
        isBosGlobal() || 
        (isAssignedToBranch(resource.data.branchId) && resource.data.get('status', 'reported') == 'draft')
      );
    }

    // Default Deny Fallback
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
